# ══════════════════════════════════════════════════════════════════
#  .env.example — Variables de entorno para Mi Portafolio Inteligente
#  Copiar a .env y completar con valores reales.
#  NUNCA commitear el .env con valores reales.
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL local (docker-compose) ──────────────────────────────
POSTGRES_USER=bysone
POSTGRES_PASSWORD=bysone

# ── PostgreSQL en producción (Neon) ────────────────────────────────
# Reemplazar por la connection string de Neon en producción.
# En local docker-compose construye la URL automáticamente.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bysone?currentSchema=bysone
SPRING_DATASOURCE_USERNAME=bysone
SPRING_DATASOURCE_PASSWORD=bysone

# ── OAuth2 — Google ────────────────────────────────────────────────
# Obtener en: https://console.cloud.google.com → APIs y servicios → Credenciales
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth2 — Microsoft ─────────────────────────────────────────────
# Obtener en: https://portal.azure.com → Azure Active Directory → Registros de aplicaciones
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── JWT ────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Generar con: openssl rand -base64 48
JWT_SECRET=

# ── RabbitMQ ───────────────────────────────────────────────────────
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ── Email (producción: cambiar por SMTP real) ──────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Frontend ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=
